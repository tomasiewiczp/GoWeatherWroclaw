# Copy this file to .env and fill in your values.
# OS environment variables always override values set here.

# Required: your OpenWeatherMap Current Weather Data API 2.5 key (free tier)
OPENWEATHER_API_KEY=your_api_key_here

# Geographic coordinates for weather data (defaults: Wrocław, Poland)
LATITUDE=51.107883
LONGITUDE=17.038538

# How often to run the ETL cycle, in seconds (default: 30)
FETCH_INTERVAL_SECONDS=30

# Port for the Prometheus /metrics and /health HTTP server (default: 8080)
METRICS_PORT=8080

# PostgreSQL connection settings
# DB_HOST=db matches the service name in docker-compose.yaml
DB_HOST=db
DB_PORT=5432
DB_USER=etl
DB_PASSWORD=etlpass
DB_NAME=weather
